# --- OS generated files ---
.DS_Store
Thumbs.db

# --- Generic temporary & backup files ---
*~
*.swp
*.swo
*.bak
*.orig
#*#

# --- Emacs ---
# Package archive (installed via package.el, reproducible from init.el)
emacs/.config/emacs/elpa/
# Native compiled elisp cache (auto-generated, platform-specific)
emacs/.config/emacs/eln-cache/
# Auto-save list (runtime state)
emacs/.config/emacs/auto-save-list/

# --- Vim ---
# Runtime state (buffers, marks, command history)
vim/.viminfo
# Netrw directory browsing history
vim/.vim/.netrwhist
# Saved views (auto-generated by mkview)
vim/.vim/view/
# Swap files (crash recovery)
vim/.vim/swap/
# Persistent undo files
vim/.vim/undo/
