#!/usr/bin/env bash
action="$1"

case "$action" in
  up)
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
    ;;
  down)
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
    ;;
  mute)
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    ;;
  mic-mute)
    wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
    ;;
esac

# 获取当前音量状态
vol=$(wpctl get-volume @DEFAULT_AUDIO_SINK@)
muted=false
if echo "$vol" | grep -q "MUTED"; then
  muted=true
fi
vol_num=$(echo "$vol" | awk '{print $2}' | bc 2>/dev/null || echo 0)
vol_percent=$(printf "%.0f" $(echo "$vol_num * 100" | bc 2>/dev/null || echo 0))

# 显示通知
if [ "$action" = "mic-mute" ]; then
  mic_vol=$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@)
  mic_muted=false
  if echo "$mic_vol" | grep -q "MUTED"; then
    mic_muted=true
  fi
  if $mic_muted; then
    dunstify -r 9992 " 麦克风已静音"
  else
    dunstify -r 9992 " 麦克风已取消静音"
  fi
elif $muted; then
  dunstify -r 9991 " 已静音"
else
  dunstify -r 9991 " 音量: $vol_percent%" -h int:value:"$vol_percent"
fi
