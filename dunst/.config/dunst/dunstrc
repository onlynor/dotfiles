[global]
    icon_theme = Adwaita
    monitor = 0
    follow = mouse
    width = 300
    height = (0, 100)
    origin = top-right
    offset = (10, 50)
    notification_limit = 0
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    icon_position = left
    max_icon_size = 32
    sticky_history = yes
    history_length = 20
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    dmenu = /usr/bin/rofi -dmenu -p dunst
    browser = /usr/bin/xdg-open
    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all
    padding = 8
    horizontal_padding = 8
    font = FiraCode Nerd Font 11
    corner_radius = 8
    transparency = 10

[urgency_low]
    background = "#2e3440"
    foreground = "#d8dee9"
    timeout = 3

[urgency_normal]
    background = "#2e3440"
    foreground = "#d8dee9"
    timeout = 3

[urgency_critical]
    background = "#2e3440"
    foreground = "#d8dee9"
    timeout = 0
